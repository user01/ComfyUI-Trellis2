# Copy to .env (gitignored), fill in values, then:
#   weights:  docker compose --profile setup run --rm model-fetch
#   serve:    docker compose up -d

# HF token with access to the GATED model (weight provisioning only):
#   https://huggingface.co/facebook/dinov3-vitl16-pretrain-lvd1689m
# Accept its license on that page, then make a token (read scope is enough):
#   https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bearer token clients must send to the hosted API:
#   Authorization: Bearer <TRELLIS_API_KEY>
# Generate one with:  openssl rand -hex 32
TRELLIS_API_KEY=replace-with-a-long-random-string
